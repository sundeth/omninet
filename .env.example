# ===========================================
# Omninet Environment Configuration
# ===========================================
# Copy this file to .env and update with your values

# Environment: dev or prd
ENVIRONMENT=dev

# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL=postgresql+asyncpg://postgres:root@localhost:5432/omnipet_dev
DATABASE_URL_PRD=postgresql+asyncpg://postgres:changeme_production@localhost:5432/omnipet_prd

# ===========================================
# Security
# ===========================================
# JWT Secret Key (generate a long random string)
SECRET_KEY=your-super-secure-secret-key-with-at-least-256-bits-of-entropy
# Token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ===========================================
# Email Configuration (SMTP)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@omnipet.com
SMTP_FROM_NAME=Omnipet

# ===========================================
# Reverse Proxy / Subpath
# ===========================================
# Set to "/dev" for the staging environment behind Cloudflare tunnel
ROOT_PATH=

# ===========================================
# CORS Origins (comma-separated)
# ===========================================
CORS_ORIGINS=https://omnipet.app.br,http://localhost:8000

# ===========================================
# File Storage
# ===========================================
MODULES_STORAGE_PATH=./storage/modules
LOGS_STORAGE_PATH=./storage/logs

# ===========================================
# Battle Configuration
# ===========================================
MAX_DAILY_BATTLES=10
MAX_TEAMS_PER_USER=1

# ===========================================
# Verification Codes
# ===========================================
VERIFICATION_CODE_EXPIRY_MINUTES=5
PAIRING_CODE_EXPIRY_MINUTES=5
