# =============================================================================
# docker-compose.deploy.yml infrastructure variables
# =============================================================================
# Copy this to .env in the same directory:
#   cp .env.example .env
# This file is read automatically by docker compose for variable substitution.
# It is NOT the same as .env.staging / .env.production (those are app configs).
# =============================================================================

# PostgreSQL container credentials
# Must match the DATABASE_URL password in .env.staging and .env.production
DB_USER=postgres
DB_PASSWORD=changeme
