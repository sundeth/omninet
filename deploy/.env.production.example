# Omninet Production Environment (.env.production)
# Place at /mnt/user/appdata/omninet/.env.production on Unraid

# Database — uses the dedicated omninet-postgres container (port 5433 on host, 5432 internally)# Use 'postgres' as the host — it resolves on the omninet-network to the postgres container.
# If you prefer an external postgres, replace 'postgres' with its IP/hostname.DATABASE_URL=postgresql+asyncpg://omninet:changeme@postgres:5432/omnipet_prd
SECRET_KEY=change-this-to-a-long-random-production-secret

# CORS — allow the public domain and localhost for testing
CORS_ORIGINS=https://omnipet.app.br,http://localhost:8000

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@omnipet.com
SMTP_FROM_NAME=Omnipet

# Storage
MODULES_STORAGE_PATH=/app/storage/modules
LOGS_STORAGE_PATH=/app/storage/logs
