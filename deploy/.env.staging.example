# Omninet Staging Environment (.env.staging)
# Place at /mnt/user/appdata/omninet/.env.staging on Unraid

# Database — uses the dedicated omninet-postgres container (port 5433 on host, 5432 internally)
# Use 'postgres' as the host — it resolves on the omninet-network to the postgres container.
# If you prefer an external postgres, replace 'postgres' with its IP/hostname.
DATABASE_URL=postgresql+asyncpg://postgres:changeme@postgres:5432/omnipet_dev
SECRET_KEY=change-this-to-a-random-secret-for-staging

# ROOT_PATH is set in docker-compose.deploy.yml (ROOT_PATH=/dev)

# CORS — allow the public domain and localhost for testing
CORS_ORIGINS=https://omnipet.app.br,http://localhost:8000

# Email (optional for staging)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@omnipet.com
SMTP_FROM_NAME=Omnipet

# Storage
MODULES_STORAGE_PATH=/app/storage/modules
LOGS_STORAGE_PATH=/app/storage/logs
